root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Python — PEP 8 uses 4 spaces
[*.py]
indent_size = 4

# Markdown — trailing spaces are significant (line breaks); do not trim
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# TOML
[*.toml]
indent_size = 2

# Shell scripts
[{*.sh,*.bash,*.zsh}]
indent_size = 2
end_of_line = lf

# Terraform / HCL
[{*.tf,*.tfvars,*.hcl}]
indent_size = 2

# YAML
[{*.yml,*.yaml}]
indent_size = 2

# Makefiles require hard tabs
[Makefile]
indent_style = tab

# Windows scripts require CRLF
[{*.ps1,*.bat,*.cmd}]
end_of_line = crlf
