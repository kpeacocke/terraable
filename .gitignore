# Distribution / packaging
dist/
build/

# ──────────────────────────────────────────────
# Node
# ──────────────────────────────────────────────
node_modules/

# ──────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────
# .terraform/ holds the provider cache — never commit
.terraform/
# NOTE: .terraform.lock.hcl is the provider lock file and MUST be committed
# (equivalent to package-lock.json). Do not add it here.
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# tfvars files may contain secrets; use *.tfvars.example for safe templates
*.tfvars
*.tfvars.json

# ──────────────────────────────────────────────
# Ansible
# ──────────────────────────────────────────────
*.retry
ansible/inventory.local.yml

# ──────────────────────────────────────────────
# Secrets / environment
# ──────────────────────────────────────────────
.env
.env.*
secrets/
tmp/

# ──────────────────────────────────────────────
# Test / scan output
# ──────────────────────────────────────────────
junit*.xml
test-results/
.scannerwork/
