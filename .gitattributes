# ──────────────────────────────────────────────
# Default: normalise all text files to LF
# ──────────────────────────────────────────────
* text=auto eol=lf

# ──────────────────────────────────────────────
# Explicit text files (enables accurate diffs)
# ──────────────────────────────────────────────
*.py         text diff=python
*.tf         text
*.tfvars     text
*.hcl        text
*.yml        text
*.yaml       text
*.json       text
*.toml       text
*.md         text diff=markdown
*.rst        text
*.sh         text eol=lf
*.bash       text eol=lf
*.env        text
*.cfg        text
*.ini        text
*.txt        text
*.xml        text
*.html       text
*.css        text
*.js         text
*.ts         text

# Windows scripts keep CRLF
*.ps1        text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# ──────────────────────────────────────────────
# Binary files — never diff or convert
# ──────────────────────────────────────────────
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.eot        binary
*.zip        binary
*.tar        binary
*.gz         binary
*.bz2        binary
*.xz         binary
*.db         binary
*.sqlite     binary
*.sqlite3    binary

# ──────────────────────────────────────────────
# Generated files — mark for GitHub language stats
# ──────────────────────────────────────────────
poetry.lock            linguist-generated=true
*.lock                 linguist-generated=true
*.min.js               linguist-generated=true
*.min.css              linguist-generated=true

# ──────────────────────────────────────────────
# Export ignores — excluded from git archive tarballs
# ──────────────────────────────────────────────
.devcontainer/         export-ignore
.github/               export-ignore
.editorconfig          export-ignore
.gitattributes         export-ignore
.gitignore             export-ignore
.markdownlint-cli2.jsonc export-ignore
.mlc_config.json       export-ignore
.yamllint.yml          export-ignore
tests/                 export-ignore
htmlcov/               export-ignore
