# Sample environment variables for Terraable
# Copy this file to .env and populate with your values.
# NEVER commit .env — it is listed in .gitignore.
# For owner/scope/rotation guidance, see docs/credentials-matrix.md.
#
# Required fields are marked [REQUIRED].
# Optional fields show a safe default where one exists.

# ── General ───────────────────────────────────────────────────────────────────

# Enable offline/mock mode. No live credentials are needed when true.
# Start with true for a first fork-and-run — switch to false when live credentials are ready.
TERRAABLE_MOCK_MODE=true

# Override the HCP Terraform hostname (leave unset to use app.terraform.io).
# TERRAABLE_TFC_HOSTNAME=app.terraform.io

# ── HCP Terraform ─────────────────────────────────────────────────────────────

# HCP Terraform API token — control-plane auth gate variable.
# Used by the local-lab backend (local_lab.py) and the UI credential panel.
# [REQUIRED unless TERRAABLE_MOCK_MODE=true]
# HCP_TERRAFORM_TOKEN=<redacted>

# HCP Terraform API token for direct Terraform CLI / hcp_terraform.py calls.
# The env var name matches Terraform CLI convention: lowercase the hostname and
# replace any non-alphanumeric character with an underscore.
# For app.terraform.io: TF_TOKEN_app_terraform_io
# For custom hostnames: replace dots and hyphens with underscores, lowercase.
# Note: set both HCP_TERRAFORM_TOKEN and TF_TOKEN_<hostname> when using both
# the Terraform CLI path and the control-plane auth gate in the same session.
# [REQUIRED unless TERRAABLE_MOCK_MODE=true]
# TF_TOKEN_app_terraform_io=<redacted>

# ── Ansible Automation Platform (AAP/AWX) ─────────────────────────────────────

# AAP or AWX controller base URL.
# [REQUIRED for showcase and lab modes]
# AWX_HOST=https://awx.example.local

# Controller username.
# [REQUIRED for lab mode bootstrap]
# AWX_USERNAME=admin

# Controller password. Prefer a service account or token approach.
# [REQUIRED for lab mode bootstrap]
# AWX_PASSWORD=<redacted>

# ── EDA ───────────────────────────────────────────────────────────────────────

# Webhook receiver port for EDA compliance drift events.
EDA_WEBHOOK_PORT=5000

# ── Repository (for AWX lab-mode bootstrap) ───────────────────────────────────

# SCM URL of forked repository used by AWX project.
# [REQUIRED for lab mode]
# TERRAABLE_SCM_URL=https://github.com/<your-username>/terraable.git

# ── Target defaults ───────────────────────────────────────────────────────────

# Default target platform. Options: openshift, aws, azure, okd, local-lab
TERRAABLE_DEFAULT_TARGET=local-lab

# Default portal implementation. Options: rhdh, backstage
TERRAABLE_DEFAULT_PORTAL=backstage

# Default security profile. Options: baseline, strict
TERRAABLE_DEFAULT_SECURITY_PROFILE=baseline

# ── AWS (for substrate_aws module) ────────────────────────────────────────────

# AWS region. Defaults to ap-southeast-2 in module variables.
# AWS_DEFAULT_REGION=ap-southeast-2

# AWS credentials. Required when target=aws.
# Prefer IAM instance profiles or aws configure for workstation use.
# Set directly here only when short-lived or CI-injected credentials are used.
# [REQUIRED for target=aws]
# AWS_ACCESS_KEY_ID=<redacted>
# AWS_SECRET_ACCESS_KEY=<redacted>

# ── GCP (for substrate_gcp module) ───────────────────────────────────────────

# Absolute path to a GCP service account JSON key file, or leave unset to use
# Application Default Credentials (gcloud auth application-default login).
# See: https://cloud.google.com/docs/authentication/application-default-credentials
# [REQUIRED for target=gcp]
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCP region. Defaults to australia-southeast1 in module variables.
# GCP_REGION=australia-southeast1

# GCP project ID.
# [REQUIRED for target=gcp]
# GCP_PROJECT_ID=<your-project-id>

# ── VMware (for substrate_vmware module) ──────────────────────────────────────

# vSphere/vCenter management host for the VMware substrate.
# [REQUIRED for target=vmware]
# VSPHERE_SERVER=vcenter.example.local
# VSPHERE_USER=<redacted>
# VSPHERE_PASSWORD=<redacted>

# ── Parallels (for substrate_parallels module) ────────────────────────────────

# Parallels Desktop management host (defaults to localhost for workstation use).
# Leave unset when running Parallels locally with default socket access.
# [REQUIRED for target=parallels when using a remote host]
# PARALLELS_MANAGEMENT_HOST=localhost

# ── Hyper-V (for substrate_hyperv module) ────────────────────────────────────

# Hyper-V host system for the substrate. Defaults to localhost.
# [REQUIRED for target=hyper-v when managing a remote Windows host]
# HYPERV_HOST_SYSTEM=localhost

# ── Azure (for substrate_azure module) ────────────────────────────────────────

# Azure location. Defaults to australiaeast in module variables.
# AZURE_LOCATION=australiaeast

# Azure credentials: set via az login or ARM_* env vars per Terraform convention.
# ARM_CLIENT_ID=<redacted>
# ARM_CLIENT_SECRET=<redacted>
# ARM_SUBSCRIPTION_ID=<redacted>
# ARM_TENANT_ID=<redacted>

# ── OpenShift / OKD ───────────────────────────────────────────────────────────

# OpenShift or OKD cluster API endpoint.
# [REQUIRED for target=openshift or target=okd]
# OPENSHIFT_API_URL=https://api.cluster.example.com:6443

# OpenShift service account or user token.
# [REQUIRED for target=openshift or target=okd]
# OPENSHIFT_TOKEN=<redacted>
